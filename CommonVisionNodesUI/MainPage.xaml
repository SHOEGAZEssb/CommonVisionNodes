<Page x:Class="CommonVisionNodesUI.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:CommonVisionNodesUI"
      xmlns:helpers="using:CommonVisionNodesUI.Helpers"
      Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <helpers:NullToCollapsedConverter x:Key="NullToCollapsed"/>
        <helpers:EmptyToCollapsedConverter x:Key="EmptyToCollapsed"/>

        <DataTemplate x:Key="ImageNodePropertiesTemplate">
            <StackPanel Spacing="12">
                <StackPanel>
                    <TextBlock Text="File Path" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="SaveImageNodePropertiesTemplate">
            <StackPanel Spacing="12">
                <StackPanel>
                    <TextBlock Text="File Path" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="BinarizeNodePropertiesTemplate">
            <StackPanel Spacing="12">
                <StackPanel>
                    <TextBlock Text="Threshold (0–255)" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="255" Value="{Binding Threshold, Mode=TwoWay}" StepFrequency="1"/>
                    <TextBlock Text="{Binding Threshold}" FontSize="13" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="SubImageNodePropertiesTemplate">
            <StackPanel Spacing="12">
                <TextBlock Text="Crop Area" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                <TextBlock Text="Drag a rectangle on the preview to define the area" FontSize="11" Foreground="#777777" TextWrapping="Wrap" Margin="0,0,0,4"/>
                <Grid ColumnSpacing="8" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="0" Grid.Column="1" Value="{Binding AreaX, Mode=TwoWay}" Minimum="0" SpinButtonPlacementMode="Compact" FontSize="13"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Y" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="0" Grid.Column="3" Value="{Binding AreaY, Mode=TwoWay}" Minimum="0" SpinButtonPlacementMode="Compact" FontSize="13"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="W" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="1" Grid.Column="1" Value="{Binding AreaWidth, Mode=TwoWay}" Minimum="1" SpinButtonPlacementMode="Compact" FontSize="13"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="H" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="1" Grid.Column="3" Value="{Binding AreaHeight, Mode=TwoWay}" Minimum="1" SpinButtonPlacementMode="Compact" FontSize="13"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="MatrixTransformNodePropertiesTemplate">
            <StackPanel Spacing="12">
                <StackPanel>
                    <TextBlock Text="Rotation (°)" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <Slider Minimum="-180" Maximum="180" Value="{Binding Angle, Mode=TwoWay}" StepFrequency="0.5"/>
                    <TextBlock Text="{Binding Angle}" FontSize="13" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
                <Grid ColumnSpacing="8" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Scale X" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="0" Grid.Column="1" Value="{Binding ScaleX, Mode=TwoWay}" SmallChange="0.1" LargeChange="0.5" SpinButtonPlacementMode="Compact" FontSize="13"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Scale Y" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="1" Grid.Column="1" Value="{Binding ScaleY, Mode=TwoWay}" SmallChange="0.1" LargeChange="0.5" SpinButtonPlacementMode="Compact" FontSize="13"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Translate X" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="2" Grid.Column="1" Value="{Binding TranslateX, Mode=TwoWay}" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Compact" FontSize="13"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Translate Y" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="3" Grid.Column="1" Value="{Binding TranslateY, Mode=TwoWay}" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Compact" FontSize="13"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ImageGeneratorNodePropertiesTemplate">
            <StackPanel Spacing="12">
                <StackPanel>
                    <TextBlock Text="Pattern" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailablePatterns}"
                              SelectedItem="{Binding Pattern, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
                <Grid ColumnSpacing="8" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Width" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="0" Grid.Column="1" Value="{Binding Width, Mode=TwoWay}" Minimum="1" Maximum="4096" SpinButtonPlacementMode="Compact" FontSize="13"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Height" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="1" Grid.Column="1" Value="{Binding Height, Mode=TwoWay}" Minimum="1" Maximum="4096" SpinButtonPlacementMode="Compact" FontSize="13"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Speed" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="2" Grid.Column="1" Value="{Binding Speed, Mode=TwoWay}" Minimum="1" Maximum="50" SpinButtonPlacementMode="Compact" FontSize="13"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="DeviceNodePropertiesTemplate">
            <StackPanel Spacing="12">
                <StackPanel>
                    <TextBlock Text="Device" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding DiscoveredDevices}"
                                  SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  PlaceholderText="No devices found"
                                  HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="1" Content="&#xE094;"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Command="{Binding DiscoverDevicesCommand}"
                                ToolTipService.ToolTip="Discover devices"
                                Padding="8,6" CornerRadius="4"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="FilterNodePropertiesTemplate">
            <StackPanel Spacing="12">
                <StackPanel>
                    <TextBlock Text="Filter" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableFilterTypes}"
                              SelectedItem="{Binding FilterType, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Kernel Size" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableKernelSizes}"
                              SelectedItem="{Binding KernelSize, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="HistogramNodePropertiesTemplate">
            <StackPanel Spacing="8">
                <TextBlock Text="Statistics" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                <Grid ColumnSpacing="8" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Mean" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Mean}" FontSize="13" Foreground="White"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Std Dev" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding StdDev}" FontSize="13" Foreground="White"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="MorphologyNodePropertiesTemplate">
            <StackPanel Spacing="12">
                <StackPanel>
                    <TextBlock Text="Operation" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableOperations}"
                              SelectedItem="{Binding Operation, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Kernel Size" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableKernelSizes}"
                              SelectedItem="{Binding KernelSize, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="NormalizeNodePropertiesTemplate">
            <StackPanel Spacing="12">
                <StackPanel>
                    <TextBlock Text="Output Min (0–255)" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="255" Value="{Binding OutputMin, Mode=TwoWay}" StepFrequency="1"/>
                    <TextBlock Text="{Binding OutputMin}" FontSize="13" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Output Max (0–255)" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="255" Value="{Binding OutputMax, Mode=TwoWay}" StepFrequency="1"/>
                    <TextBlock Text="{Binding OutputMax}" FontSize="13" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="BlobNodePropertiesTemplate">
            <StackPanel Spacing="12">
                <StackPanel>
                    <TextBlock Text="Foreground Threshold (0–255)" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="255" Value="{Binding ForegroundThreshold, Mode=TwoWay}" StepFrequency="1"/>
                    <TextBlock Text="{Binding ForegroundThreshold}" FontSize="13" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel>
                    <CheckBox Content="Invert Foreground" IsChecked="{Binding InvertForeground, Mode=TwoWay}" Foreground="White" FontSize="13"/>
                </StackPanel>
                <StackPanel>
                    <CheckBox Content="8-Connectivity" IsChecked="{Binding Use8Connectivity, Mode=TwoWay}" Foreground="White" FontSize="13"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Min Area (pixels)" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <NumberBox Value="{Binding MinArea, Mode=TwoWay}" Minimum="1" SpinButtonPlacementMode="Compact" FontSize="13"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Max Area (0 = no limit)" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <NumberBox Value="{Binding MaxArea, Mode=TwoWay}" Minimum="0" SpinButtonPlacementMode="Compact" FontSize="13"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Max Blob Count (0 = no limit)" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <NumberBox Value="{Binding MaxBlobCount, Mode=TwoWay}" Minimum="0" SpinButtonPlacementMode="Compact" FontSize="13"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Results" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding BlobCount}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="blob(s) found" FontSize="12" Foreground="#888888"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="PolimagoClassifyNodePropertiesTemplate">
            <StackPanel Spacing="12">
                <StackPanel>
                    <TextBlock Text="Classifier File (.clf)" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ClassifierPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="13" PlaceholderText="Path to .clf file"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Min Quality (0.0–1.0)" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <Slider Minimum="0" Maximum="1" Value="{Binding MinQuality, Mode=TwoWay}" StepFrequency="0.05"/>
                    <TextBlock Text="{Binding MinQuality}" FontSize="13" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Results" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding ResultCount}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="classification(s)" FontSize="12" Foreground="#888888"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <helpers:NodePropertiesTemplateSelector x:Key="NodePropertiesSelector"
            ImageNodeTemplate="{StaticResource ImageNodePropertiesTemplate}"
            SaveImageNodeTemplate="{StaticResource SaveImageNodePropertiesTemplate}"
            DeviceNodeTemplate="{StaticResource DeviceNodePropertiesTemplate}"
            BinarizeNodeTemplate="{StaticResource BinarizeNodePropertiesTemplate}"
            SubImageNodeTemplate="{StaticResource SubImageNodePropertiesTemplate}"
            MatrixTransformNodeTemplate="{StaticResource MatrixTransformNodePropertiesTemplate}"
            ImageGeneratorNodeTemplate="{StaticResource ImageGeneratorNodePropertiesTemplate}"
            FilterNodeTemplate="{StaticResource FilterNodePropertiesTemplate}"
            HistogramNodeTemplate="{StaticResource HistogramNodePropertiesTemplate}"
            MorphologyNodeTemplate="{StaticResource MorphologyNodePropertiesTemplate}"
            BlobNodeTemplate="{StaticResource BlobNodePropertiesTemplate}"
            NormalizeNodeTemplate="{StaticResource NormalizeNodePropertiesTemplate}"
            PolimagoClassifyNodeTemplate="{StaticResource PolimagoClassifyNodePropertiesTemplate}"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    Padding="8" Spacing="8"
                    Background="#333333">
            <!-- Input -->
            <DropDownButton IsEnabled="{Binding IsEditingEnabled}"
                            Padding="12,6" Background="#4A90D9" Foreground="White" CornerRadius="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14"/>
                    <TextBlock Text="Input" VerticalAlignment="Center"/>
                </StackPanel>
                <DropDownButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Image" Command="{Binding Graph.AddImageNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE710;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Device" Command="{Binding Graph.AddDeviceNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE714;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Generator" Command="{Binding Graph.AddImageGeneratorNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE768;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>

            <!-- Output -->
            <DropDownButton IsEnabled="{Binding IsEditingEnabled}"
                            Padding="12,6" Background="#66BB6A" Foreground="White" CornerRadius="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74E;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14"/>
                    <TextBlock Text="Output" VerticalAlignment="Center"/>
                </StackPanel>
                <DropDownButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Save Image" Command="{Binding Graph.AddSaveImageNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74E;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>

            <!-- Processing -->
            <DropDownButton IsEnabled="{Binding IsEditingEnabled}"
                            Padding="12,6" Background="#FF9800" Foreground="White" CornerRadius="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE71C;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14"/>
                    <TextBlock Text="Processing" VerticalAlignment="Center"/>
                </StackPanel>
                <DropDownButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Binarize" Command="{Binding Graph.AddBinarizeNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE71C;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="SubImage" Command="{Binding Graph.AddSubImageNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE740;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Transform" Command="{Binding Graph.AddMatrixTransformNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE809;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Filter" Command="{Binding Graph.AddFilterNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE71C;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Morphology" Command="{Binding Graph.AddMorphologyNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE71C;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Normalize" Command="{Binding Graph.AddNormalizeNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE793;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>

            <!-- Analysis -->
            <DropDownButton IsEnabled="{Binding IsEditingEnabled}"
                            Padding="12,6" Background="#009688" Foreground="White" CornerRadius="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE9D9;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14"/>
                    <TextBlock Text="Analysis" VerticalAlignment="Center"/>
                </StackPanel>
                <DropDownButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Histogram" Command="{Binding Graph.AddHistogramNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE9D9;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Blob" Command="{Binding Graph.AddBlobNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8B1;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Polimago Classify" Command="{Binding Graph.AddPolimagoClassifyNodeCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8BA;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>

            <Border Width="1" Background="#555555" Margin="8,2"/>

            <Button Content="Initialize"
                    IsEnabled="{Binding IsEditingEnabled}"
                    Padding="12,6" CornerRadius="4"/>
            <Button Content="Execute" Command="{Binding Graph.ExecuteGraphCommand}"
                    IsEnabled="{Binding IsEditingEnabled}"
                    Padding="12,6" CornerRadius="4"/>
            <Button Content="{Binding RunButtonText}" Command="{Binding Graph.ToggleRunCommand}"
                    Background="{Binding RunButtonBackground}"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Padding="12,6" Foreground="White" CornerRadius="4"/>

            <Border Width="1" Background="#555555" Margin="8,2"/>

            <Button x:Name="GenerateCodeButton" Content="&#xE943; Generate Code"
                    Click="GenerateCodeButton_Click"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Padding="12,6" Background="#7B1FA2" Foreground="White" CornerRadius="4"/>

            <Border Width="1" Background="#555555" Margin="8,2"/>

            <Button x:Name="SaveGraphButton" Content="&#xE74E; Save"
                    Click="SaveGraphButton_Click"
                    IsEnabled="{Binding IsEditingEnabled}"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Padding="12,6" CornerRadius="4"/>
            <Button x:Name="LoadGraphButton" Content="&#xE8E5; Load"
                    Click="LoadGraphButton_Click"
                    IsEnabled="{Binding IsEditingEnabled}"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Padding="12,6" CornerRadius="4"/>
        </StackPanel>

        <!-- Main content: Canvas + Properties Panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Graph Canvas -->
            <Border x:Name="GraphCanvasContainer" Grid.Column="0" Background="#1E1E1E">
                <Grid>
                    <Canvas x:Name="GridCanvas" IsHitTestVisible="False"/>
                    <Canvas x:Name="GraphCanvas"
                            Background="Transparent"
                            PointerPressed="GraphCanvas_PointerPressed"
                            PointerMoved="GraphCanvas_PointerMoved"
                            PointerReleased="GraphCanvas_PointerReleased"
                            PointerWheelChanged="GraphCanvas_PointerWheelChanged"
                            KeyDown="GraphCanvas_KeyDown"
                            IsTabStop="True"
                            AllowFocusOnInteraction="True">
                        <Canvas.RenderTransform>
                            <CompositeTransform x:Name="CanvasTransform"/>
                        </Canvas.RenderTransform>
                    </Canvas>
                </Grid>
            </Border>

            <!-- Properties Panel -->
            <Border Grid.Column="1" Width="280" Background="#252525"
                    BorderBrush="#3C3C3C" BorderThickness="1,0,0,0">
                <Grid>
                    <!-- No selection placeholder -->
                    <TextBlock Text="Click a node to configure"
                               Visibility="{Binding NoSelectionVisibility}"
                               Foreground="#666666" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Properties editor -->
                    <StackPanel Visibility="{Binding PropertiesPanelVisibility}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding SelectedNodeTitle}" FontSize="16" FontWeight="Bold"
                                           Foreground="White" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedNodeTypeName}" FontSize="12"
                                           Foreground="#888888"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="&#xE74D;"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    Command="{Binding RemoveSelectedNodeCommand}"
                                    IsEnabled="{Binding IsEditingEnabled}"
                                    ToolTipService.ToolTip="Remove node (Delete)"
                                    Padding="8,6" CornerRadius="4"
                                    Background="#D32F2F" Foreground="White"
                                    VerticalAlignment="Top"/>
                        </Grid>

                        <Border Margin="0,12,0,0"/>

                        <!-- Port Info -->
                        <StackPanel Spacing="4" Margin="0,0,0,12"
                                    Visibility="{Binding Graph.SelectedNode, Converter={StaticResource NullToCollapsed}}">
                            <TextBlock Text="Ports" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>

                            <!-- Inputs -->
                            <ItemsControl ItemsSource="{Binding Graph.SelectedNode.InputPorts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="6" Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#4FC3F7"
                                                     VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding Port.Name}" FontSize="12"
                                                               Foreground="White" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding TypeName}" FontSize="11"
                                                               Foreground="#777777"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Port.Description}" FontSize="11"
                                                           Foreground="#888888" TextWrapping="Wrap"
                                                           Visibility="{Binding Port.Description, Converter={StaticResource EmptyToCollapsed}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Outputs -->
                            <ItemsControl ItemsSource="{Binding Graph.SelectedNode.OutputPorts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="6" Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#FFB74D"
                                                     VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding Port.Name}" FontSize="12"
                                                               Foreground="White" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding TypeName}" FontSize="11"
                                                               Foreground="#777777"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Port.Description}" FontSize="11"
                                                           Foreground="#888888" TextWrapping="Wrap"
                                                           Visibility="{Binding Port.Description, Converter={StaticResource EmptyToCollapsed}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <ContentControl Content="{Binding Graph.SelectedNode}"
                                        ContentTemplateSelector="{StaticResource NodePropertiesSelector}"
                                        IsEnabled="{Binding IsPropertiesContentEnabled}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#252525" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Padding="12,4">
            <StackPanel Orientation="Horizontal" Spacing="24">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="FPS:" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding FpsText}" Foreground="White" FontSize="12" VerticalAlignment="Center" MinWidth="40"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="CPU:" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CpuText}" Foreground="White" FontSize="12" VerticalAlignment="Center" MinWidth="50"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="RAM:" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MemoryText}" Foreground="White" FontSize="12" VerticalAlignment="Center" MinWidth="60"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="GPU:" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding GpuText}" Foreground="White" FontSize="12" VerticalAlignment="Center" MinWidth="50"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
