<UserControl
    x:Class="CommonVisionNodesUI.Controls.NodeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="using:CommonVisionNodesUI.Controls">

    <Border x:Name="NodeBorder" CornerRadius="8"
            BorderBrush="#555555" BorderThickness="1"
            Background="#2D2D2D"
            Width="200">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header (drag handle) -->
            <Border x:Name="HeaderBorder" Grid.Row="0"
                    CornerRadius="7,7,0,0" Padding="12,8"
                    PointerPressed="Header_PointerPressed"
                    PointerMoved="Header_PointerMoved"
                    PointerReleased="Header_PointerReleased">
                <TextBlock x:Name="TitleText"
                           Foreground="White" FontWeight="SemiBold" FontSize="13"/>
            </Border>

            <!-- Ports -->
            <Grid Grid.Row="1" Padding="0,4,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Input Ports -->
                <ItemsControl x:Name="InputPortsList" Grid.Column="0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Padding="4,4">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{Binding Tooltip}" Opened="PortToolTip_Opened"/>
                                </ToolTipService.ToolTip>
                                <Ellipse Width="12" Height="12" Fill="#4FC3F7"
                                         PointerPressed="Port_PointerPressed"/>
                                <TextBlock Text="{Binding Port.Name}" Margin="6,0,0,0"
                                           VerticalAlignment="Center" FontSize="12"
                                           Foreground="#CCCCCC"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Output Ports -->
                <ItemsControl x:Name="OutputPortsList" Grid.Column="1">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Padding="4,4">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{Binding Tooltip}" Opened="PortToolTip_Opened"/>
                                </ToolTipService.ToolTip>
                                <TextBlock Text="{Binding Port.Name}" Margin="0,0,6,0"
                                           VerticalAlignment="Center" FontSize="12"
                                           Foreground="#CCCCCC"/>
                                <Ellipse Width="12" Height="12" Fill="#FFB74D"
                                         PointerPressed="Port_PointerPressed"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Summary / custom content -->
            <TextBlock x:Name="SummaryText" Grid.Row="2"
                       Visibility="Collapsed"
                       FontSize="11" Foreground="#999999"
                       TextTrimming="CharacterEllipsis"
                       Padding="8,0,8,6"/>

            <!-- Execution time -->
            <TextBlock x:Name="ExecutionTimeText" Grid.Row="2"
                       Visibility="Collapsed"
                       FontSize="10" Foreground="#777777"
                       HorizontalAlignment="Right"
                       Padding="8,0,8,6"/>
        
            <!-- Image preview -->
            <local:CvbImageDisplay x:Name="ImagePreview" Grid.Row="3"
                                   Height="120" Margin="4,0,4,4"
                                   Visibility="Collapsed"/>

            <!-- Crop image preview (SubImage node) -->
            <local:CropImageDisplay x:Name="CropPreview" Grid.Row="3"
                                    Height="120" Margin="4,0,4,4"
                                    Visibility="Collapsed"/>

            <!-- Histogram preview -->
            <local:HistogramDisplay x:Name="HistogramPreview" Grid.Row="3"
                                    Height="120" Margin="4,0,4,4"
                                    Visibility="Collapsed"/>

            <!-- Blob image preview with bounding boxes -->
            <local:BlobImageDisplay x:Name="BlobPreview" Grid.Row="3"
                                    Height="120" Margin="4,0,4,4"
                                    Visibility="Collapsed"/>

            <!-- Polimago preview with classification result overlays -->
            <local:PolimagoImageDisplay x:Name="PolimagoPreview" Grid.Row="3"
                                        Height="120" Margin="4,0,4,4"
                                        Visibility="Collapsed"/>

            <!-- Generic visualizer preview -->
            <local:GenericVisualizerDisplay x:Name="GenericVisualizerPreview" Grid.Row="3"
                                            Height="120" Margin="4,0,4,4"
                                            Visibility="Collapsed"/>
        </Grid>
    </Border>
</UserControl>
