<UserControl
    x:Class="CommonVisionNodesUI.Controls.CvbImageDisplay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#1A1A1A" CornerRadius="4">
        <!-- Image display -->
        <Image x:Name="DisplayImage" Stretch="Uniform"/>

        <!-- Empty state -->
        <TextBlock x:Name="PlaceholderText"
                   Text="No image"
                   Foreground="#555555" FontSize="12"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Info overlay -->
        <Border x:Name="InfoOverlay"
                VerticalAlignment="Bottom" HorizontalAlignment="Left"
                Background="#AA000000" CornerRadius="0,4,0,4"
                Padding="6,2" Visibility="Collapsed">
            <TextBlock x:Name="InfoText" FontSize="10" Foreground="#CCCCCC"/>
        </Border>
    </Grid>
</UserControl>
