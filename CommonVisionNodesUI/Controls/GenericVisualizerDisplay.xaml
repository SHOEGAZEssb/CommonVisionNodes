<UserControl
    x:Class="CommonVisionNodesUI.Controls.GenericVisualizerDisplay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CommonVisionNodesUI.Controls">

    <Grid Background="#1A1A1A"
          CornerRadius="4"
          PointerWheelChanged="Root_PointerWheelChanged">

        <!-- Image mode -->
        <local:CvbImageDisplay x:Name="ImageDisplay" Visibility="Collapsed"/>

        <!-- String list mode -->
        <ScrollViewer x:Name="ListScroll"
                      Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsList" Padding="6,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="11" Foreground="#CCCCCC"
                                   Padding="0,1" TextWrapping="NoWrap" FontFamily="Consolas"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Placeholder -->
        <TextBlock x:Name="PlaceholderText"
                   Text="No data"
                   Foreground="#555555" FontSize="12"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

    </Grid>
</UserControl>
