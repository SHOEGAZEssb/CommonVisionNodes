<UserControl
    x:Class="CommonVisionNodesUI.Controls.HistogramDisplay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#1A1A1A" CornerRadius="4">
        <Canvas x:Name="HistogramCanvas"/>

        <TextBlock x:Name="PlaceholderText"
                   Text="No data"
                   Foreground="#555555" FontSize="12"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <Border x:Name="StatsOverlay"
                VerticalAlignment="Bottom" HorizontalAlignment="Left"
                Background="#AA000000" CornerRadius="0,4,0,4"
                Padding="6,2" Visibility="Collapsed">
            <TextBlock x:Name="StatsText" FontSize="10" Foreground="#CCCCCC"/>
        </Border>
    </Grid>
</UserControl>
