<UserControl
    x:Class="CommonVisionNodesUI.Controls.CropImageDisplay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="#1A1A1A" CornerRadius="4">
        <Image x:Name="DisplayImage" Stretch="Uniform"/>

        <TextBlock x:Name="PlaceholderText"
                   Text="No image"
                   Foreground="#555555" FontSize="12"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsHitTestVisible="False"/>

        <Border x:Name="InfoOverlay"
                VerticalAlignment="Bottom" HorizontalAlignment="Left"
                Background="#AA000000" CornerRadius="0,4,0,4"
                Padding="6,2" Visibility="Collapsed"
                IsHitTestVisible="False">
            <TextBlock x:Name="InfoText" FontSize="10" Foreground="#CCCCCC"/>
        </Border>

        <Canvas x:Name="OverlayCanvas"
                Background="Transparent"
                PointerPressed="Overlay_PointerPressed"
                PointerMoved="Overlay_PointerMoved"
                PointerReleased="Overlay_PointerReleased">
            <Rectangle x:Name="CropRect"
                       Stroke="#00BFFF" StrokeThickness="2"
                       Fill="#3300BFFF"
                       Visibility="Collapsed"/>
        </Canvas>
    </Grid>
</UserControl>
